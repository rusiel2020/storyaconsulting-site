---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/source-serif-4';

const title = 'Storya Consulting — Your AI Team. Built in Your Office. This Morning.';
const description =
  'On-site AI workshops for PR, Financial Communications and Publishing teams. Half-day. No prerequisites. You leave with a working AI team, not a certificate.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://storyaconsulting.com" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://storyaconsulting.com" />
  </head>
  <body>
    <main>
      <header class="masthead">
        <div class="masthead__inner">
          <div class="masthead__identity">
            <img src="/paolo.jpg" alt="Paolo Danese" class="masthead__portrait" width="72" height="72" />
            <div>
              <p class="masthead__wordmark">Storya Consulting</p>
              <p class="masthead__byline">Paolo Danese · Singapore</p>
            </div>
          </div>
          <nav class="masthead__meta" aria-label="Issue">
            <span>Issue 01</span>
            <span class="dot">·</span>
            <span>2026</span>
          </nav>
        </div>
        <hr class="rule rule--draw" aria-hidden="true" />
      </header>

      <section class="hero">
        <p class="eyebrow">An offer, not a course</p>
        <h1 class="hero__head">
          Your AI team.<br />
          Built in your office.<br />
          <em>This morning.</em>
        </h1>
        <p class="hero__sub">
          On-site AI workshops for PR, financial communications and publishing teams. Half a day. No prerequisites. You leave with a working AI team, not a certificate.
        </p>
        <p class="hero__tags">
          <span>AI for PR</span>
          <span class="sep"></span>
          <span>Financial Communications</span>
          <span class="sep"></span>
          <span>Publishing</span>
        </p>
      </section>

      <section class="contrast">
        <p class="section-num">01</p>
        <h2 class="section-head">The competition</h2>
        <p class="section-deck">Cookie-cutter courses. Siloed learning. Here is what Singapore's training market is selling, and what is missing from all of it.</p>

        <div class="numerals">
          <figure class="num">
            <span class="num__digit" data-target="83">0</span>
            <figcaption>courses on the SkillsFuture portal</figcaption>
          </figure>
          <figure class="num">
            <span class="num__digit" data-target="100" data-suffix="s">0</span>
            <figcaption>hours of class time, on average, learning what you do not need</figcaption>
          </figure>
          <figure class="num num--accent">
            <span class="num__digit">0</span>
            <figcaption>of them will come to your office</figcaption>
          </figure>
        </div>

        <div class="contrast__columns">
          <div class="col">
            <h3 class="col__head">What they sell</h3>
            <ul class="list list--quiet">
              <li>RAG, vector databases, LangChain, LangGraph, CrewAI</li>
              <li>Python programming as the entry fee</li>
              <li>Two hundred hours of classroom instruction</li>
              <li>A certificate at the end</li>
            </ul>
          </div>
          <div class="col col--accent">
            <h3 class="col__head">What you get from Storya</h3>
            <ul class="list list--strong">
              <li>A solution built around your actual workflow</li>
              <li>In-person, two-way feedback while we build</li>
              <li>A same-day working AI team, not a certificate</li>
              <li>Time savings, measured in hours per person, per week</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="ba">
        <p class="section-num">02</p>
        <h2 class="section-head">The before and after</h2>
        <p class="section-deck">One workflow. Built in half a day. Recovered every morning, permanently.</p>

        <div class="ba__grid">
          <div class="ba__cell">
            <p class="ba__label">Before</p>
            <p class="ba__numeral">2<span class="unit">hrs</span></p>
            <p class="ba__body">Every morning, before writing a word. Reviewing press releases, regulatory sites, news feeds. The same hour and a half, every day, before the work that pays starts.</p>
          </div>
          <div class="ba__cell ba__cell--after">
            <p class="ba__label">After</p>
            <p class="ba__numeral">9<span class="unit">am</span></p>
            <p class="ba__body">Your research briefing is already done. Formatted, sourced, ready to write from. Spend your time where it counts the most.</p>
          </div>
        </div>
      </section>

      <section class="reqs">
        <p class="section-num">03</p>
        <h2 class="section-head">What is required</h2>
        <p class="section-deck">Three things. No new software to buy. No infrastructure to set up. No prerequisites.</p>

        <ol class="reqs__list">
          <li>
            <p class="reqs__num">01</p>
            <h3 class="reqs__head">A laptop</h3>
            <p class="reqs__body">Any Mac or Windows machine. No admin rights required.</p>
          </li>
          <li>
            <p class="reqs__num">02</p>
            <h3 class="reqs__head">An AI subscription</h3>
            <p class="reqs__body">What you already pay for. Claude, ChatGPT or Gemini. We also work with free open-source models.</p>
          </li>
          <li>
            <p class="reqs__num">03</p>
            <h3 class="reqs__head">Four hours</h3>
            <p class="reqs__body">A half-day workshop. You leave with a working AI team running on your own machine.</p>
          </li>
        </ol>
      </section>

      <section class="how">
        <p class="section-num">04</p>
        <h2 class="section-head">How it works</h2>
        <p class="section-deck">Audit first, workshop second. The audit maps your workflow; the workshop deploys your first AI team. Followed by 30 days of follow-up, bundled in.</p>

        <ol class="how__steps">
          <li>
            <p class="how__step">Step 01</p>
            <h3 class="how__head">AI Workflow Audit</h3>
            <p class="how__body">A multi-day diagnostic run on your team's actual tools and workflow. We map where AI fits, surface the highest-value opportunities, and deliver a full recommendations report. The front door of every engagement.</p>
          </li>
          <li>
            <p class="how__step">Step 02</p>
            <h3 class="how__head">Half-day workshop</h3>
            <p class="how__body">Your first AI team built in the room. Your workflow, your documents. You leave with it running on your own machine.</p>
          </li>
        </ol>

        <div class="how__after">
          <p><strong>Then, 30-day follow-up.</strong> Bundled in. We are on call as you operate it.</p>
          <p><strong>Ongoing, partnership.</strong> Optional. We keep you current as the tools and best practices evolve.</p>
        </div>
      </section>

      <section class="pricing">
        <p class="section-num">05</p>
        <h2 class="section-head">Pricing</h2>
        <p class="section-deck">Audit-first. The audit maps where AI fits in your workflow. The workshop deploys it. All engagements on-site by default. Pricing covers up to eight participants. Corporate and group rates available on request.</p>

        <div class="pricing__tiers">
          <article class="tier">
            <p class="tier__label">Entry</p>
            <h3 class="tier__name">Workshop standalone</h3>
            <p class="tier__price">SGD <span class="figure">2,500</span></p>
            <p class="tier__body">Half-day session. Your first AI team built in the room. Works on the day. Yours to keep.</p>
            <a class="tier__cta" href="mailto:paolo@storyaconsulting.com?subject=Workshop%20enquiry">Email to enquire</a>
          </article>
          <article class="tier tier--depth">
            <p class="tier__label">Bundle</p>
            <h3 class="tier__name">Audit + Workshop</h3>
            <p class="tier__price">SGD <span class="figure">7,500</span></p>
            <p class="tier__body">Multi-day AI Workflow Audit followed by the half-day workshop. Full diagnostic, full deployment.</p>
            <a class="tier__cta" href="mailto:paolo@storyaconsulting.com?subject=Audit%20and%20Workshop%20enquiry">Email to enquire</a>
          </article>
          <article class="tier">
            <p class="tier__label">Partnership</p>
            <h3 class="tier__name">Retainer</h3>
            <p class="tier__price">SGD <span class="figure">500</span><span class="cadence">/month</span></p>
            <p class="tier__body">Quarterly in-person sessions, online resources, workshop discounts for other teams. Optional.</p>
            <a class="tier__cta" href="mailto:paolo@storyaconsulting.com?subject=Retainer%20enquiry">Email to enquire</a>
          </article>
        </div>
      </section>

      <section class="why">
        <p class="section-num">06</p>
        <h2 class="section-head">Why not a course</h2>
        <p class="section-deck">Six things you will not get anywhere else.</p>

        <div class="why__grid">
          <div>
            <h3 class="why__head">A two-way experience</h3>
            <p>On-site only. Your conference room, your team, your real workflow. Not a generic classroom.</p>
          </div>
          <div>
            <h3 class="why__head">Agents that write like you</h3>
            <p>Your voice. Your clients. Your documents. The AI team learns from your own materials.</p>
          </div>
          <div>
            <h3 class="why__head">Ecosystem-agnostic</h3>
            <p>Google Workspace, Microsoft 365, or standalone. We pick what you already have. You buy nothing new.</p>
          </div>
          <div>
            <h3 class="why__head">Supervisor-first</h3>
            <p>Supervisor trained before the team. Guardrails and approvals set top-down. People empowered, leaders in control.</p>
          </div>
          <div>
            <h3 class="why__head">IT-reality-aware</h3>
            <p>Corporate firewalls, MDM policies, endpoint protection. We have fallbacks. Most trainers will not work around these.</p>
          </div>
          <div>
            <h3 class="why__head">Still there after the day</h3>
            <p>Thirty days of follow-up bundled in. Tweaks, adjustments, expansion. The collaboration continues.</p>
          </div>
        </div>
      </section>

      <section class="bio">
        <p class="section-num">07</p>
        <h2 class="section-head">Who is behind this</h2>

        <p class="bio__body">
          Paolo Danese founded <strong>Storya</strong>, an AI publishing platform that scaled to 3,000 users and 1,000 independent authors across more than 20 languages before being wound down in 2023. Before Storya, he spent close to a decade as a senior financial journalist at <strong>Euromoney Institutional Investor</strong>, where he ran <em>GlobalRMB</em>, the first English-language publication covering China's currency internationalisation, and later led content and media relations for institutional finance clients as <strong>VP at FleishmanHillard</strong> in Hong Kong. He is a published author of five epic fantasy novels and runs his own Amazon Ads campaigns. The workflows he teaches are the ones he runs on his own work every day.
        </p>
      </section>

      <section class="cta">
        <p class="cta__line">The market teaches AI.</p>
        <p class="cta__line cta__line--accent">We deploy it.</p>
        <p class="cta__sub">Ready to build your first AI team? Half-day. On-site. This week.</p>
        <a class="cta__email" href="mailto:paolo@storyaconsulting.com">paolo@storyaconsulting.com</a>
      </section>

      <footer class="foot">
        <hr class="rule" />
        <div class="foot__row">
          <p>Storya Consulting · Singapore · 2026</p>
          <p>
            <a href="https://www.linkedin.com/in/paolodanese/" rel="me noopener">LinkedIn</a>
          </p>
        </div>
      </footer>
    </main>

    <script>
      // Numerical counter — runs once per numeral when first scrolled into view.
      const easeOutQuart = (t: number) => 1 - Math.pow(1 - t, 4);

      const animate = (el: HTMLElement) => {
        const target = Number(el.dataset.target);
        if (!target) return;
        const suffix = el.dataset.suffix ?? '';
        const duration = 900;
        const start = performance.now();
        const fmt = (n: number) =>
          n >= 1000 ? n.toLocaleString('en-US') : String(n);
        const tick = (now: number) => {
          const t = Math.min(1, (now - start) / duration);
          const v = Math.round(target * easeOutQuart(t));
          el.textContent = fmt(v) + suffix;
          if (t < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };

      const targets = document.querySelectorAll<HTMLElement>('[data-target]');
      if ('IntersectionObserver' in window && targets.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                animate(e.target as HTMLElement);
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.4 }
        );
        targets.forEach((t) => io.observe(t));
      } else {
        targets.forEach(animate);
      }

      // Section fade-in.
      const reveals = document.querySelectorAll<HTMLElement>('section, .masthead, .foot');
      if ('IntersectionObserver' in window) {
        const io2 = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-in');
                io2.unobserve(e.target);
              }
            }
          },
          { threshold: 0.1 }
        );
        reveals.forEach((el) => io2.observe(el));
      } else {
        reveals.forEach((el) => el.classList.add('is-in'));
      }
    </script>

    <style is:global>
      :root {
        --paper: oklch(98% 0.008 75);
        --paper-2: oklch(96% 0.012 75);
        --ink: oklch(18% 0.02 50);
        --ink-soft: oklch(34% 0.018 55);
        --ink-mute: oklch(54% 0.015 60);
        --rule: oklch(82% 0.012 60);
        --accent: oklch(48% 0.16 28);
        --accent-soft: oklch(60% 0.12 30);
        --max: 1100px;
        --prose: 38rem;
        --display: 'Fraunces Variable', 'Fraunces', Georgia, serif;
        --body: 'Source Serif 4 Variable', 'Source Serif 4', Georgia, serif;
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--paper);
        color: var(--ink);
      }

      body {
        font-family: var(--body);
        font-size: 17px;
        line-height: 1.55;
        font-feature-settings: 'kern', 'liga', 'onum';
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      ::selection { background: var(--accent); color: var(--paper); }

      main {
        max-width: var(--max);
        margin: 0 auto;
        padding: 2.25rem clamp(1.25rem, 4vw, 3rem) 4rem;
      }

      a { color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--rule); transition: border-color .2s, color .2s; }
      a:hover { color: var(--accent); border-bottom-color: var(--accent); }

      hr.rule {
        border: 0;
        height: 1px;
        background: var(--rule);
        margin: 0;
      }
      hr.rule--draw {
        background: var(--accent);
        height: 2px;
        margin-top: 1.5rem;
        transform-origin: left center;
        transform: scaleX(0);
        animation: ruleDraw 700ms cubic-bezier(.22,1,.36,1) 250ms forwards;
      }
      @keyframes ruleDraw { to { transform: scaleX(1); } }

      /* Reveal */
      section, .masthead, .foot { opacity: 0; transform: translateY(8px); transition: opacity .55s ease-out, transform .55s ease-out; }
      section.is-in, .masthead.is-in, .foot.is-in { opacity: 1; transform: none; }
      .masthead { transition-delay: 0ms; }

      /* Masthead */
      .masthead__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
      }
      .masthead__identity {
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .masthead__portrait {
        width: 56px;
        height: 56px;
        border-radius: 999px;
        object-fit: cover;
        background: var(--paper-2);
      }
      .masthead__wordmark {
        font-family: var(--display);
        font-variation-settings: 'opsz' 36, 'wght' 600, 'SOFT' 0;
        font-size: 1.25rem;
        margin: 0;
        letter-spacing: -0.01em;
      }
      .masthead__byline {
        margin: .15rem 0 0;
        color: var(--ink-mute);
        font-size: .85rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .masthead__meta {
        font-family: var(--display);
        font-variation-settings: 'opsz' 14, 'wght' 500;
        color: var(--ink-mute);
        font-size: .8rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }
      .masthead__meta .dot { margin: 0 .5rem; color: var(--accent); }

      /* Hero */
      .hero {
        margin-top: 5rem;
        margin-bottom: 7rem;
      }
      .eyebrow {
        font-family: var(--display);
        font-variation-settings: 'opsz' 14, 'wght' 500;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        font-size: .78rem;
        color: var(--accent);
        margin: 0 0 1.5rem;
      }
      .hero__head {
        font-family: var(--display);
        font-variation-settings: 'opsz' 144, 'wght' 420, 'SOFT' 30;
        font-size: clamp(2.6rem, 7.4vw, 5.4rem);
        line-height: 0.96;
        letter-spacing: -0.025em;
        margin: 0 0 2rem;
        max-width: 18ch;
      }
      .hero__head em {
        font-style: italic;
        font-variation-settings: 'opsz' 144, 'wght' 360, 'SOFT' 100, 'WONK' 1;
        color: var(--accent);
      }
      .hero__sub {
        font-family: var(--body);
        font-size: 1.18rem;
        line-height: 1.5;
        max-width: var(--prose);
        margin: 0 0 2rem;
        color: var(--ink-soft);
      }
      .hero__tags {
        font-family: var(--display);
        font-variation-settings: 'opsz' 14, 'wght' 500;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: .82rem;
        color: var(--ink-mute);
        display: flex;
        flex-wrap: wrap;
        gap: 0 .9rem;
        margin: 0;
      }
      .hero__tags .sep {
        display: inline-block;
        width: 24px;
        border-bottom: 1px solid var(--rule);
        margin-bottom: 4px;
      }

      /* Sections */
      section { padding: 4.5rem 0; }
      section + section { border-top: 1px solid var(--rule); }
      .section-num {
        font-family: var(--display);
        font-variation-settings: 'opsz' 14, 'wght' 500, 'onum' 1;
        color: var(--accent);
        font-size: .82rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        margin: 0 0 .9rem;
      }
      .section-head {
        font-family: var(--display);
        font-variation-settings: 'opsz' 96, 'wght' 480;
        font-size: clamp(1.9rem, 4vw, 2.6rem);
        line-height: 1.05;
        letter-spacing: -0.018em;
        margin: 0 0 .7rem;
      }
      .section-deck {
        font-family: var(--body);
        color: var(--ink-soft);
        font-size: 1.08rem;
        max-width: var(--prose);
        margin: 0 0 2.4rem;
      }

      /* Numerals block */
      .numerals {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin: 1.4rem 0 3.5rem;
        padding: 2rem 0;
        border-top: 1px solid var(--rule);
        border-bottom: 1px solid var(--rule);
      }
      .num { margin: 0; }
      .num__digit {
        font-family: var(--display);
        font-variation-settings: 'opsz' 144, 'wght' 380, 'SOFT' 0, 'WONK' 0, 'onum' 0;
        font-size: clamp(4.5rem, 11vw, 9rem);
        line-height: 0.9;
        display: block;
        letter-spacing: -0.04em;
        color: var(--ink);
        font-feature-settings: 'lnum';
      }
      .num--accent .num__digit { color: var(--accent); }
      .num figcaption {
        font-family: var(--body);
        font-size: .98rem;
        color: var(--ink-soft);
        margin-top: .5rem;
        max-width: 22ch;
        line-height: 1.4;
      }
      @media (max-width: 720px) {
        .numerals { grid-template-columns: 1fr; gap: 1.4rem; }
        .num figcaption { max-width: none; }
      }

      .contrast__columns {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
      }
      .col__head {
        font-family: var(--display);
        font-variation-settings: 'opsz' 24, 'wght' 520;
        font-size: 1.05rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        margin: 0 0 1rem;
        color: var(--ink-mute);
      }
      .col--accent .col__head { color: var(--accent); }
      .list { list-style: none; padding: 0; margin: 0; }
      .list li {
        padding: .85rem 0;
        border-top: 1px solid var(--rule);
        font-size: 1rem;
      }
      .list li:last-child { border-bottom: 1px solid var(--rule); }
      .list--quiet li { color: var(--ink-mute); text-decoration: line-through; text-decoration-color: var(--rule); text-decoration-thickness: 1px; }
      .list--strong li { color: var(--ink); }
      @media (max-width: 720px) {
        .contrast__columns { grid-template-columns: 1fr; gap: 2rem; }
      }

      /* Before / After */
      .ba__grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        border-top: 1px solid var(--rule);
        border-bottom: 1px solid var(--rule);
      }
      .ba__cell {
        padding: 2.4rem 2rem;
      }
      .ba__cell + .ba__cell {
        border-left: 1px solid var(--rule);
      }
      .ba__label {
        font-family: var(--display);
        font-variation-settings: 'opsz' 14, 'wght' 540;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        font-size: .78rem;
        color: var(--ink-mute);
        margin: 0 0 .5rem;
      }
      .ba__cell--after .ba__label { color: var(--accent); }
      .ba__numeral {
        font-family: var(--display);
        font-variation-settings: 'opsz' 144, 'wght' 380, 'SOFT' 0;
        font-size: clamp(4rem, 9vw, 7.5rem);
        line-height: 1;
        margin: 0 0 .8rem;
        letter-spacing: -0.035em;
      }
      .ba__cell--after .ba__numeral { color: var(--accent); }
      .ba__numeral .unit {
        font-variation-settings: 'opsz' 24, 'wght' 460;
        font-size: 0.32em;
        margin-left: .3em;
        text-transform: lowercase;
        color: var(--ink-mute);
      }
      .ba__body {
        margin: 0;
        color: var(--ink-soft);
        max-width: 32ch;
      }
      @media (max-width: 720px) {
        .ba__grid { grid-template-columns: 1fr; }
        .ba__cell + .ba__cell { border-left: 0; border-top: 1px solid var(--rule); }
      }

      /* Reqs */
      .reqs__list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem;
      }
      .reqs__num {
        font-family: var(--display);
        font-variation-settings: 'opsz' 14, 'wght' 540;
        color: var(--accent);
        letter-spacing: 0.22em;
        font-size: .78rem;
        margin: 0 0 .8rem;
      }
      .reqs__head {
        font-family: var(--display);
        font-variation-settings: 'opsz' 36, 'wght' 460;
        font-size: 1.5rem;
        margin: 0 0 .6rem;
        letter-spacing: -0.012em;
      }
      .reqs__body {
        margin: 0;
        color: var(--ink-soft);
      }
      @media (max-width: 720px) { .reqs__list { grid-template-columns: 1fr; gap: 1.8rem; } }

      /* How */
      .how__steps {
        list-style: none;
        padding: 0;
        margin: 0 0 2.4rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2.5rem;
      }
      .how__step {
        font-family: var(--display);
        font-variation-settings: 'opsz' 14, 'wght' 540;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        font-size: .78rem;
        color: var(--accent);
        margin: 0 0 .5rem;
      }
      .how__head {
        font-family: var(--display);
        font-variation-settings: 'opsz' 48, 'wght' 460;
        font-size: 1.7rem;
        margin: 0 0 .6rem;
        letter-spacing: -0.014em;
      }
      .how__body { margin: 0; color: var(--ink-soft); }
      .how__after {
        border-top: 1px solid var(--rule);
        padding-top: 1.4rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2.5rem;
        color: var(--ink-soft);
      }
      .how__after p { margin: 0; }
      .how__after strong { color: var(--ink); }
      @media (max-width: 720px) {
        .how__steps, .how__after { grid-template-columns: 1fr; gap: 1.6rem; }
      }

      /* Pricing */
      .pricing__tiers {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        border-top: 1px solid var(--rule);
        border-bottom: 1px solid var(--rule);
      }
      .tier {
        padding: 2.2rem 1.8rem 2.4rem;
      }
      .tier + .tier { border-left: 1px solid var(--rule); }
      .tier__label {
        font-family: var(--display);
        font-variation-settings: 'opsz' 14, 'wght' 540;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        font-size: .78rem;
        color: var(--ink-mute);
        margin: 0 0 .5rem;
      }
      .tier--depth .tier__label { color: var(--accent); }
      .tier__name {
        font-family: var(--display);
        font-variation-settings: 'opsz' 36, 'wght' 460;
        font-size: 1.3rem;
        margin: 0 0 1rem;
        letter-spacing: -0.012em;
      }
      .tier__price {
        font-family: var(--display);
        font-variation-settings: 'opsz' 14, 'wght' 460;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--ink-mute);
        margin: 0 0 1rem;
      }
      .tier__price .figure {
        font-variation-settings: 'opsz' 144, 'wght' 380;
        font-size: 3rem;
        letter-spacing: -0.03em;
        color: var(--ink);
        text-transform: none;
        margin: 0 .15em;
        font-feature-settings: 'lnum';
      }
      .tier--depth .tier__price .figure { color: var(--accent); }
      .tier__price .cadence {
        font-size: .8rem;
        text-transform: lowercase;
        letter-spacing: 0.04em;
      }
      .tier__body {
        margin: 0 0 1.6rem;
        color: var(--ink-soft);
        font-size: .98rem;
      }
      .tier__cta {
        font-family: var(--display);
        font-variation-settings: 'opsz' 14, 'wght' 540;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: .78rem;
        border-bottom: 1px solid currentColor;
        padding-bottom: 2px;
      }
      @media (max-width: 720px) {
        .pricing__tiers { grid-template-columns: 1fr; }
        .tier + .tier { border-left: 0; border-top: 1px solid var(--rule); }
      }

      /* Why */
      .why__grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2.4rem 2.4rem;
      }
      .why__head {
        font-family: var(--display);
        font-variation-settings: 'opsz' 24, 'wght' 480;
        font-size: 1.18rem;
        margin: 0 0 .5rem;
        letter-spacing: -0.01em;
      }
      .why__grid p { margin: 0; color: var(--ink-soft); }
      @media (max-width: 900px) { .why__grid { grid-template-columns: 1fr 1fr; } }
      @media (max-width: 600px) { .why__grid { grid-template-columns: 1fr; gap: 1.6rem; } }

      /* Bio */
      .bio__body {
        max-width: 38rem;
        font-size: 1.08rem;
        line-height: 1.65;
      }
      .bio__body strong { font-weight: 600; }
      .bio__body em { font-style: italic; }

      /* CTA */
      .cta {
        text-align: left;
        padding: 6rem 0 5rem;
      }
      .cta__line {
        font-family: var(--display);
        font-variation-settings: 'opsz' 144, 'wght' 380, 'SOFT' 0;
        font-size: clamp(2.4rem, 6.5vw, 4.6rem);
        line-height: 1;
        margin: 0;
        letter-spacing: -0.025em;
      }
      .cta__line--accent {
        color: var(--accent);
        font-style: italic;
        font-variation-settings: 'opsz' 144, 'wght' 360, 'SOFT' 100, 'WONK' 1;
      }
      .cta__sub {
        margin: 1.6rem 0 1.2rem;
        color: var(--ink-soft);
        max-width: var(--prose);
      }
      .cta__email {
        font-family: var(--display);
        font-variation-settings: 'opsz' 36, 'wght' 480;
        font-size: 1.4rem;
        border-bottom: 2px solid var(--accent);
        padding-bottom: 3px;
        color: var(--ink);
        word-break: break-all;
      }
      .cta__email:hover { color: var(--accent); }

      /* Footer */
      .foot { margin-top: 4rem; padding-top: 1.4rem; }
      .foot__row {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding-top: 1.4rem;
        font-size: .85rem;
        color: var(--ink-mute);
      }
      .foot__row p { margin: 0; }
      .foot__row a { color: var(--ink-mute); border-bottom-color: transparent; }
      .foot__row a:hover { color: var(--accent); border-bottom-color: var(--accent); }

      @media (max-width: 720px) {
        .masthead__inner { flex-direction: column; align-items: flex-start; gap: 1rem; }
        .masthead__meta { font-size: .72rem; }
        .foot__row { flex-direction: column; }
      }

      @media (prefers-reduced-motion: reduce) {
        section, .masthead, .foot { opacity: 1; transform: none; transition: none; }
        hr.rule--draw { animation: none; transform: none; }
      }
    </style>
  </body>
</html>
